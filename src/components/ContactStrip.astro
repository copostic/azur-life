---
import { SITE, PHONE, WHATSAPP } from '~/lib/constants';

interface Props {
  title: string;
  addressLine: string;
  hours: string;
  mapButton?: string;
}
const { title, addressLine, hours } = Astro.props;
---

<section id="contact" class="contact-strip section section-cream">
  <div class="container-page">
    <div class="contact-center">
      <p class="eyebrow">Contact</p>
      <h2>{title}</h2>
      <ul class="contact-list" role="list">
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s7-7.5 7-13a7 7 0 1 0-14 0c0 5.5 7 13 7 13z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <span>{addressLine}</span>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .6 3.6 1 1 0 0 1-.25 1z"/>
          </svg>
          <a href={`tel:${PHONE.raw}`}>{PHONE.display}</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="M3 7l9 6 9-6"/>
          </svg>
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6 4h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7l-5 4v-4H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
          </svg>
          <a href={WHATSAPP.url('Consultation expertise immobilière')} target="_blank" rel="noopener">WhatsApp</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="9"/>
            <path d="M12 7v5l3 2"/>
          </svg>
          <span>{hours}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .contact-center {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }
  .contact-center h2 {
    margin: 0.6rem 0 1.5rem;
  }
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .contact-list li {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    color: var(--color-ink);
    font-size: 1rem;
    font-weight: 300;
  }
  .contact-list svg {
    width: 20px;
    height: 20px;
    color: var(--color-gold);
    flex-shrink: 0;
  }
  .contact-list a {
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 400;
    transition: color 0.3s ease;
  }
  .contact-list a:hover { color: var(--color-gold); }
</style>
