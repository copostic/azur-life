---
interface LegalLink {
  label: string;
  href: string;
  dataAttr?: string;
}
interface Props {
  tagline: string;
  crossLinkLabel: string;
  crossLinkHref: string;
  legal: readonly LegalLink[];
  languages: string;
  copyright: string;
}
const { tagline, crossLinkLabel, crossLinkHref, legal, languages, copyright } = Astro.props;
---

<footer class="site-footer">
  <div class="container-page footer-inner">
    <div class="footer-brand">
      <h2 class="footer-name">AZUR LIFE</h2>
      <p class="footer-tagline">{tagline}</p>
    </div>

    <hr class="hairline" />

    <div class="footer-bottom">
      <div class="footer-legal">
        <nav aria-label="Légal">
          <ul class="legal-links" role="list">
            {legal.map((l) => (
              <li>
                {l.dataAttr ? (
                  <a href={l.href} data-cookie-settings>{l.label}</a>
                ) : (
                  <a href={l.href}>{l.label}</a>
                )}
              </li>
            ))}
          </ul>
        </nav>
        <p class="footer-langs">{languages}</p>
      </div>
      <div class="footer-meta">
        <a href={crossLinkHref} class="lang-switch" rel="alternate">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" width="18" height="18">
            <circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a14 14 0 0 1 0 18M12 3a14 14 0 0 0 0 18"/>
          </svg>
          {crossLinkLabel}
        </a>
        <p class="copyright">{copyright}</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-cream);
    border-top: 1px solid var(--color-outline);
    padding-block: 3.5rem;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .footer-brand {
    text-align: center;
  }
  .footer-name {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-navy);
    margin: 0 0 0.5rem;
  }
  .footer-tagline {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--color-muted);
    margin: 0;
    max-width: 540px;
    margin-inline: auto;
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .legal-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .legal-links a {
    color: var(--color-ink);
    text-decoration: none;
    font-size: 0.7rem;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    transition: color 0.3s ease;
  }
  .legal-links a:hover { color: var(--color-gold); }
  .footer-langs {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    color: var(--color-muted);
  }
  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.8rem;
  }
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    background: white;
    border: 1px solid var(--color-outline);
    color: var(--color-navy);
    text-decoration: none;
    font-weight: 400;
    font-size: 0.85rem;
    transition: border-color 0.3s ease;
  }
  .lang-switch:hover { border-color: var(--color-gold); }
  .copyright {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 300;
    color: var(--color-muted);
  }
  @media (max-width: 768px) {
    .footer-bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-meta {
      align-items: center;
    }
    .legal-links {
      justify-content: center;
    }
  }
</style>
