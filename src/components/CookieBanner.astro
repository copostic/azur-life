---
interface Props {
  text: string;
  accept: string;
  reject: string;
}
const { text, accept, reject } = Astro.props;
---

<div
  id="cookie-banner"
  class="cookie-banner"
  role="dialog"
  aria-live="polite"
  aria-label="Cookies"
  hidden
>
  <p>{text}</p>
  <div class="cb-actions">
    <button type="button" class="btn btn-ghost" data-cookie="reject">{reject}</button>
    <button type="button" class="btn btn-primary" data-cookie="accept">{accept}</button>
  </div>
</div>

<script>
  (function () {
    const KEY = 'al_consent_v2';
    const banner = document.getElementById('cookie-banner');
    if (!banner) return;

    function update(state: 'granted' | 'denied') {
      const g = (window as any).gtag as ((...args: unknown[]) => void) | undefined;
      if (typeof g === 'function') {
        g('consent', 'update', {
          ad_storage: state,
          analytics_storage: state,
          ad_user_data: state,
          ad_personalization: state,
        });
      }
      // Also push to dataLayer for GTM-driven custom triggers
      (window as any).dataLayer = (window as any).dataLayer || [];
      (window as any).dataLayer.push({ event: 'consent_update', consent_state: state });
    }

    function decide(state: 'granted' | 'denied') {
      try { localStorage.setItem(KEY, state); } catch (_) {}
      update(state);
      banner!.hidden = true;
    }

    let saved: string | null = null;
    try { saved = localStorage.getItem(KEY); } catch (_) {}

    if (saved === 'granted' || saved === 'denied') {
      update(saved as 'granted' | 'denied');
    } else {
      banner.hidden = false;
    }

    banner.addEventListener('click', (e) => {
      const t = e.target as HTMLElement;
      if (!t || !(t instanceof HTMLElement)) return;
      const btn = t.closest('[data-cookie]') as HTMLElement | null;
      if (!btn) return;
      const action = btn.getAttribute('data-cookie');
      decide(action === 'accept' ? 'granted' : 'denied');
    });

    // Footer "cookie settings" link reopens the banner
    document.querySelectorAll('[data-cookie-settings]').forEach((el) => {
      el.addEventListener('click', (ev) => {
        ev.preventDefault();
        banner.hidden = false;
      });
    });
  })();
</script>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 70;
    background: var(--color-ink);
    color: var(--color-paper);
    border-radius: var(--radius-card);
    padding: 1rem 1.2rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: 0 18px 40px -16px rgba(0, 0, 0, 0.5);
    max-width: 880px;
    margin-inline: auto;
  }
  .cookie-banner p { margin: 0; font-size: 0.88rem; line-height: 1.5; flex: 1; color: #E7DFCB; }
  .cb-actions { display: flex; gap: 0.5rem; flex-shrink: 0; }
  .cb-actions .btn { padding-block: 0.55rem; padding-inline: 1rem; min-height: 40px; font-size: 0.88rem; }
  .cb-actions .btn-ghost {
    background: transparent;
    color: var(--color-paper);
    border-color: rgba(244, 239, 227, 0.4);
  }
  .cb-actions .btn-ghost:hover { background: rgba(244, 239, 227, 0.1); }
  @media (max-width: 640px) {
    .cookie-banner { flex-direction: column; align-items: stretch; bottom: 88px; }
    .cb-actions { justify-content: flex-end; }
  }
</style>
