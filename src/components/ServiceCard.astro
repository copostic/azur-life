---
interface Props {
  ref: string;
  anchor: string;
  intent?: string | null;
  title: string;
  body: string;
}
const { ref, anchor, intent, title, body } = Astro.props;
---

<article
  id={anchor}
  class="card service-card reveal"
  data-anchor={anchor}
  data-intent={intent ?? ''}
>
  <div class="card-head">
    <span class="ref-code">{ref}</span>
  </div>
  <h3>{title}</h3>
  <p>{body}</p>
</article>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
  }
  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .service-card h3 {
    font-size: 1.35rem;
    margin: 0;
    color: var(--color-navy);
  }
  .service-card p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    line-height: 1.65;
    font-weight: 300;
  }
</style>
