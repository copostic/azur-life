---
import { PHONE, WHATSAPP } from '~/lib/constants';

interface Props {
  primary: 'call' | 'whatsapp';
  callLabel: string;
  whatsappLabel: string;
  formLabel: string;
  formAnchor?: string;
  waPrefill?: string;
}

const {
  primary,
  callLabel,
  whatsappLabel,
  formLabel,
  formAnchor = '#lead-form',
  waPrefill = '',
} = Astro.props;
---

<div class="sticky-mobile" data-primary={primary}>
  {primary === 'whatsapp' ? (
    <>
      <a class="cta-cell cta-primary" href={WHATSAPP.url(waPrefill)} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7l-5 4v-4H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/></svg>
        <span>{whatsappLabel}</span>
      </a>
      <a class="cta-cell" href={`tel:${PHONE.raw}`}>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .6 3.6 1 1 0 0 1-.25 1z"/></svg>
        <span>{callLabel}</span>
      </a>
    </>
  ) : (
    <>
      <a class="cta-cell cta-primary" href={`tel:${PHONE.raw}`}>
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .6 3.6 1 1 0 0 1-.25 1z"/></svg>
        <span>{callLabel}</span>
      </a>
      <a class="cta-cell" href={WHATSAPP.url(waPrefill)} target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6 4h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7l-5 4v-4H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/></svg>
        <span>{whatsappLabel}</span>
      </a>
    </>
  )}
  <a class="cta-cell" href={formAnchor}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="18" rx="2"/><path d="M8 8h8M8 12h8M8 16h5"/></svg>
    <span>{formLabel}</span>
  </a>
</div>

<style>
  .sticky-mobile {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 60;
    display: none;
    background: rgba(251, 249, 244, 0.98);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid var(--color-outline);
    box-shadow: 0 -6px 18px -10px rgba(26, 28, 30, 0.18);
    padding: 0.55rem;
    gap: 0.4rem;
  }
  @media (max-width: 768px) {
    .sticky-mobile { display: grid; grid-template-columns: 1fr 1fr 1fr; }
    body { padding-bottom: 78px; }
  }
  .cta-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 0.55rem 0.4rem;
    border-radius: 0;
    background: var(--color-cream-warm);
    color: var(--color-ink);
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    min-height: 60px;
    line-height: 1;
  }
  .cta-cell svg { width: 22px; height: 22px; }
  .cta-primary {
    background: var(--color-navy);
    color: white;
  }
</style>
