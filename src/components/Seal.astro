---
interface Props {
  ringText?: string;
  size?: number;
  ariaLabel?: string;
}

const {
  ringText = "AZUR · LIFE · EXPERTISE · IMMOBILIÈRE · BEAULIEU · ",
  size = 140,
  ariaLabel = 'Sceau Azur Life',
} = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 200"
  width={size}
  height={size}
  role="img"
  aria-label={ariaLabel}
  class="seal"
>
  <defs>
    <path id="seal-ring-path" d="M 100,100 m -78,0 a 78,78 0 1,1 156,0 a 78,78 0 1,1 -156,0" fill="none" />
  </defs>

  <!-- Outer rings -->
  <circle cx="100" cy="100" r="92" fill="none" stroke="currentColor" stroke-width="1.2" opacity="0.5" />
  <circle cx="100" cy="100" r="86" fill="none" stroke="currentColor" stroke-width="2" />
  <circle cx="100" cy="100" r="64" fill="none" stroke="currentColor" stroke-width="0.8" opacity="0.6" />

  <!-- Circular text -->
  <text font-family="var(--font-mono)" font-size="10.5" fill="currentColor" letter-spacing="2.4" font-weight="500">
    <textPath href="#seal-ring-path" startOffset="0">
      {ringText.repeat(3)}
    </textPath>
  </text>

  <!-- Center: balance scale -->
  <g stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" transform="translate(100 100)">
    <!-- pillar -->
    <line x1="0" y1="-30" x2="0" y2="28" />
    <!-- base -->
    <line x1="-16" y1="32" x2="16" y2="32" />
    <line x1="-10" y1="28" x2="10" y2="28" />
    <!-- beam -->
    <line x1="-32" y1="-30" x2="32" y2="-30" />
    <!-- left pan -->
    <line x1="-32" y1="-30" x2="-32" y2="-18" stroke-dasharray="1 3" />
    <path d="M -44,-14 Q -32,-2 -20,-14" />
    <!-- right pan -->
    <line x1="32" y1="-30" x2="32" y2="-18" stroke-dasharray="1 3" />
    <path d="M 20,-14 Q 32,-2 44,-14" />
    <!-- top knot -->
    <circle cx="0" cy="-32" r="2.5" fill="currentColor" />
  </g>
</svg>

<style>
  .seal {
    color: var(--color-brass);
    display: block;
  }
</style>
