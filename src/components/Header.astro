---
import { PHONE, WHATSAPP } from '~/lib/constants';

interface NavLink {
  label: string;
  href: string;
}

interface Props {
  metaLine: string;
  primary: 'call' | 'whatsapp';
  primaryLabel: string;
  secondaryLabel: string;
  secondaryHref?: string;
  waPrefill?: string;
  nav?: readonly NavLink[];
}

const {
  metaLine,
  primary,
  primaryLabel,
  secondaryLabel,
  secondaryHref = '#lead-form',
  waPrefill = '',
  nav = [],
} = Astro.props;

const primaryHref =
  primary === 'whatsapp'
    ? WHATSAPP.url(waPrefill)
    : `tel:${PHONE.raw}`;
---

<nav class="site-header">
  <div class="container-page header-inner">
    <a href="/" class="brand" aria-label="AZUR LIFE — Accueil">
      <img class="h-8" src="/img/logo-azur-life-blue.png" alt="Azur Life Expertise Immobilière Logo" />
    </a>

    <div class="header-nav">
      {nav.map((l) => <a href={l.href}>{l.label}</a>)}
    </div>

    <div class="header-cta">
      <a
        href={secondaryHref}
        class="btn btn-ghost header-secondary"
        data-secondary-cta
      >
        {secondaryLabel}
      </a>
      <a
        href={primaryHref}
        class="btn btn-primary header-primary"
        rel={primary === 'whatsapp' ? 'noopener' : undefined}
        target={primary === 'whatsapp' ? '_blank' : undefined}
      >
        {primary === 'whatsapp' ? (
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
            <path d="M6 4h12a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-7l-5 4v-4H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z"/>
          </svg>
        ) : (
          <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
            <path d="M6.6 10.8a15 15 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1 11.4 11.4 0 0 0 .6 3.6 1 1 0 0 1-.25 1z"/>
          </svg>
        )}
        <span>{primaryLabel}</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 249, 244, 0.9);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid var(--color-outline);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 1rem;
  }
  .brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-navy);
  }
  .header-nav {
    display: none;
    align-items: center;
    gap: 2rem;
  }
  .header-nav a {
    font-size: 0.7rem;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    color: var(--color-muted);
    transition: color 0.3s ease;
  }
  .header-nav a:hover { color: var(--color-gold); }
  .header-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .header-secondary {
    padding: 0.7rem 1.2rem;
    font-size: 0.7rem;
  }
  .header-primary {
    padding: 0.7rem 1.4rem;
    font-size: 0.7rem;
  }
  @media (min-width: 920px) {
    .header-nav { display: flex; }
  }
  @media (max-width: 640px) {
    .header-secondary { display: none; }
    .header-primary span { display: none; }
    .header-primary { padding-inline: 1rem; }
  }
</style>
