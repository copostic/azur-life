---
// Court-of-appeal credential chip. Displays the official
// "Cour d'appel — Expert judiciaire" seal beside a short caption.
// Used as an authority signal near the hero CTA and the lead form.
interface Props {
  caption: string;
  sub: string;
  alt: string;
  tone?: 'light' | 'dark';
  align?: 'start' | 'center';
  class?: string;
}

const {
  caption,
  sub,
  alt,
  tone = 'light',
  align = 'start',
  class: className = '',
} = Astro.props;
---

<div class={`expert-badge tone-${tone} align-${align} ${className}`.trim()}>
  <img
    src="/img/cours-appel-expert-natalia.png"
    alt={alt}
    loading="lazy"
    decoding="async"
  />
  <span class="expert-badge-text">
    <span class="expert-badge-caption">{caption}</span>
    <span class="expert-badge-sub" set:html={sub}></span>
  </span>
</div>

<style>
  .expert-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.55rem 1rem 0.55rem 0.6rem;
    border: 1px solid rgba(197, 160, 89, 0.45);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(2px);
  }
  .expert-badge.align-center { justify-content: center; }
  .expert-badge img {
    width: 6rem;
    display: block;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.25));
    flex-shrink: 0;
  }
  .expert-badge-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    text-align: left;
  }
  .expert-badge-caption {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .expert-badge-sub {
    font-size: 0.9rem;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  /* On dark backgrounds (hero image, navy form section) */
  .tone-light .expert-badge-caption { color: #fff; }
  .tone-light .expert-badge-sub { color: var(--color-gold-light); }
  /* On light backgrounds */
  .tone-dark {
    background: rgba(197, 160, 89, 0.08);
    border-color: rgba(197, 160, 89, 0.55);
  }
  .tone-dark .expert-badge-caption { color: var(--color-navy); }
  .tone-dark .expert-badge-sub { color: var(--color-gold-dim); }
</style>
