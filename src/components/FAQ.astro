---
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items: readonly FaqItem[];
}
const { items } = Astro.props;
---

<div class="faq-list reveal">
  {items.map((item, i) => (
    <details class="faq-item" open={i === 0}>
      <summary>{item.q}</summary>
      <div class="faq-body">{item.a}</div>
    </details>
  ))}
</div>

<style>
  .faq-list { max-width: 820px; margin-inline: auto; }
</style>
