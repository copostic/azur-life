---
interface HeroVariant {
  eyebrow: string;
  h1Html: string;
  sub: string;
}

interface Props {
  variants?: Record<string, HeroVariant>;
  defaultVariant?: HeroVariant;
  staticHero?: {
    eyebrow: string;
    h1Html: string;
    sub: string;
  };
  trustPills?: readonly string[];
  primary?: 'call' | 'whatsapp';
  primaryLabel?: string;
  secondaryLabel: string;
  microCopy?: string;
  waPrefill?: string;
  ringText?: string;
  formAnchor?: string;
}

const {
  variants,
  defaultVariant,
  staticHero,
  secondaryLabel,
  formAnchor = '#lead-form',
} = Astro.props;

const hero = staticHero ?? defaultVariant!;
const variantsJson = variants ? JSON.stringify(variants) : null;
---

<section class="hero">
  <div class="hero-bg">
    <div class="hero-overlay"></div>
    <img src="/img/hero-riviera.jpg" alt="French Riviera Coastline" class="hero-img" />
  </div>
  <div class="hero-content">
    <p class="hero-eyebrow" data-hero-eyebrow>{hero.eyebrow}</p>
    <h1 data-hero-h1 set:html={hero.h1Html}></h1>
    <p class="hero-sub" data-hero-sub>{hero.sub}</p>
    <div class="hero-cta">
      <a href={formAnchor} class="btn btn-hero">{secondaryLabel}</a>
    </div>
  </div>
</section>

{variantsJson && (
  <script type="application/json" id="hero-variants" set:html={variantsJson} is:inline></script>
  <script>
    (function () {
      const node = document.getElementById('hero-variants');
      if (!node) return;
      let variants: Record<string, { eyebrow: string; h1Html: string; sub: string }> = {};
      try { variants = JSON.parse(node.textContent || '{}'); } catch (_) { return; }
      const intent = new URLSearchParams(location.search).get('intent') || '';
      if (!intent || !variants[intent]) return;
      const v = variants[intent];
      const eyebrow = document.querySelector('[data-hero-eyebrow]');
      const h1 = document.querySelector('[data-hero-h1]');
      const sub = document.querySelector('[data-hero-sub]');
      if (eyebrow) eyebrow.textContent = v.eyebrow;
      if (h1) h1.innerHTML = v.h1Html;
      if (sub) sub.textContent = v.sub;
      // Highlight any service card matching this intent
      document.querySelectorAll<HTMLElement>('[data-intent]').forEach((el) => {
        if (el.getAttribute('data-intent') === intent) el.classList.add('is-highlighted');
      });
      // Pre-select the form select if a matching value exists
      const sel = document.querySelector<HTMLSelectElement>('select[name="type"]');
      if (sel) {
        const opt = Array.from(sel.options).find((o) => o.value === intent);
        if (opt) sel.value = intent;
      }
    })();
  </script>
)}

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    z-index: 1;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    max-width: 1100px;
    padding: 2rem clamp(1.5rem, 4vw, 3rem);
  }
  .hero-eyebrow {
    font-size: 0.75rem;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--color-gold-light);
    margin: 0 0 1.5rem;
  }
  .hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 6rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: white;
    margin: 0 0 1.5rem;
  }
  .hero-content h1 :global(strong) {
    font-style: italic;
    font-weight: 400;
  }
  .hero-content h1 :global(em) {
    font-style: italic;
  }
  .hero-sub {
    font-size: clamp(1.05rem, 1.5vw, 1.25rem);
    font-weight: 300;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 2.5rem;
    max-width: 64ch;
    margin-inline: auto;
  }
  .hero-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  .btn-hero {
    background: white;
    color: var(--color-navy);
    padding: 1.2rem 2.5rem;
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    transition: all 0.4s ease;
    border: 1px solid transparent;
  }
  .btn-hero:hover {
    background: var(--color-gold);
    color: white;
  }
  @media (max-width: 768px) {
    .hero { min-height: 80vh; }
  }
</style>
